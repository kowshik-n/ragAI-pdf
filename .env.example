# Copy this file to .env and add your values.
OPENAI_API_KEY=your_openai_api_key

# Qdrant and Redis are configured in docker-compose.
QDRANT_COLLECTION_NAME=langchainjs-testing

# For local Docker Compose, the app defaults to http://localhost:8000.
# For production behind a proxy, leave this blank or set it to your public domain.
NEXT_PUBLIC_API_BASE_URL=
